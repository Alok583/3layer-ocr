# ─── OpenRouter API Keys ─────────────────────────────────────────────────────
# Get keys at: https://openrouter.ai/keys
# Supports multiple keys for rate-limit rotation:
OPENROUTER_API_KEY_1=sk-or-v1-your-key-here
OPENROUTER_API_KEY_2=sk-or-v1-your-second-key-here

# Or use a single key (comma-separated for multiple):
# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ─── Google Sheets Integration (optional) ────────────────────────────────────
# Service account credentials JSON file path
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
# Sheet ID from URL: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ─── Server Configuration ────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
