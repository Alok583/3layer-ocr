# Google Cloud Service Account JSON credentials file
# Used for both Google Vision API and Google Sheets API
# Get it from: https://console.cloud.google.com → IAM → Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# OCR.space API Key
# Get a free key (no credit card) from: https://ocr.space/OCRAPI
# Free tier: 25,000 requests/month
OCR_SPACE_API_KEY=your_ocr_space_api_key_here

# Google Sheet ID
# Found in your sheet URL: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID_HERE/edit
# Make sure to share the sheet with your service account email as Editor
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Server configuration (optional)
PORT=3000
HOST=0.0.0.0
